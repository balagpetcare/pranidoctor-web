{
  "name": "pranidoctor-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:changed": "node scripts/lint-changed.mjs",
    "lint:release": "node scripts/lint-release.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:production-env": "tsx scripts/validate-production-env.ts",
    "db:client:sync": "node scripts/copy-prisma-client-from-backend.mjs",
    "postinstall": "node scripts/copy-prisma-client-from-backend.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "locations:generate-csv": "tsx scripts/generate-master-csv-from-hdx-tmp.ts",
    "locations:import": "tsx scripts/import-locations.ts",
    "locations:import:dry-run": "tsx scripts/import-locations.ts --dry-run",
    "locations:normalize:unions": "tsx scripts/locations/normalize-unions.ts",
    "locations:normalize:villages": "tsx scripts/locations/normalize-villages.ts",
    "locations:normalize": "npm run locations:normalize:unions && npm run locations:normalize:villages",
    "locations:qa": "tsx scripts/locations/location-csv-qa.ts",
    "locations:suggest-union-mappings": "tsx scripts/locations/suggest-union-parent-mappings.ts",
    "locations:union-mapping-helper": "tsx scripts/locations/build-union-mapping-review-helper.ts",
    "locations:union-mapping-apply-approved": "tsx scripts/locations/apply-approved-union-mapping-helper.ts",
    "locations:union-mapping-simple-review": "tsx scripts/locations/build-union-mapping-simple-review.ts",
    "locations:union-mapping-simple-apply": "tsx scripts/locations/apply-union-mapping-simple-review.ts",
    "locations:audit:nuhil-unions": "tsx scripts/locations/audit-nuhil-union-integration.ts",
    "locations:nuhil:backup-snapshot": "tsx scripts/locations/backup-nuhil-full-hierarchy-snapshot.ts",
    "locations:nuhil:normalize-full": "tsx scripts/locations/normalize-nuhil-full-hierarchy.ts",
    "locations:nuhil:compare": "tsx scripts/locations/compare-current-vs-nuhil-hierarchy.ts",
    "locations:nuhil:switch-csv": "tsx scripts/locations/switch-to-nuhil-hierarchy-csv.ts",
    "locations:audit:clear-refs": "tsx scripts/locations/audit-location-references-before-clear.ts",
    "locations:clear-for-nuhil-rebuild": "tsx scripts/locations/clear-location-master-for-nuhil-rebuild.ts",
    "locations:report-duplicates": "tsx scripts/locations/report-location-duplicates.ts",
    "locations:duplicates": "tsx scripts/locations/report-location-duplicates.ts",
    "locations:dedupe:dry-run": "tsx scripts/locations/dedupe-locations.ts",
    "locations:dedupe:apply": "tsx scripts/locations/dedupe-locations.ts --apply",
    "locations:dedupe": "tsx scripts/locations/dedupe-locations.ts",
    "locations:indexes:check": "tsx scripts/locations/check-location-unique-indexes.ts",
    "locations:migration:preflight": "tsx scripts/locations/location-migration-preflight.ts",
    "locations:resolve-district-code-conflicts": "tsx scripts/locations/resolve-district-trim-code-conflicts.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-underline": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "isomorphic-dompurify": "^3.12.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.75.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
