// Prani Doctor — Prisma schema (MVP)
// https://pranidoctor.com/

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CUSTOMER
  DOCTOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum AnimalCategory {
  PET
  LIVESTOCK
  OTHER
}

enum ServiceRequestStatus {
  SUBMITTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TreatmentRecordStatus {
  DRAFT
  FINALIZED
}

enum PrescriptionStatus {
  ACTIVE
  VOIDED
}

enum BillingRecordStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  adminProfile    AdminProfile?
  doctorProfile   DoctorProfile?
  customerProfile CustomerProfile?
  notifications   Notification[]
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  licenseNumber  String
  specialization String?
  bio            String?
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedRequests    ServiceRequest[]
  treatmentRecords    TreatmentRecord[]
  prescriptions       Prescription[]
  billingRecords      BillingRecord[]
}

model CustomerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  locale      String?  @default("bn-BD")
  addressJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  animals         AnimalProfile[]
  serviceRequests ServiceRequest[]
  billingRecords  BillingRecord[]
}

model AnimalProfile {
  id              String         @id @default(cuid())
  customerId      String
  name            String
  species         String
  breed           String?
  category        AnimalCategory @default(OTHER)
  dateOfBirth     DateTime?
  sex             String?
  microchipOrTag  String?
  notes           String?
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customer        CustomerProfile   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceRequests ServiceRequest[]
  treatmentRecords TreatmentRecord[]
  prescriptions   Prescription[]

  @@index([customerId])
}

model Area {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  parentId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent   Area?  @relation("AreaHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Area[] @relation("AreaHierarchy")

  serviceRequests ServiceRequest[]

  @@index([parentId])
}

model ServiceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serviceRequests ServiceRequest[]
}

model ServiceRequest {
  id                     String               @id @default(cuid())
  customerId             String
  animalId               String
  areaId                 String
  serviceCategoryId      String
  assignedDoctorId       String?
  status                 ServiceRequestStatus @default(SUBMITTED)
  urgency                String?
  symptoms               String?
  preferredWindow        String?
  locationNotes          String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  completedAt            DateTime?

  customer        CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  animal          AnimalProfile   @relation(fields: [animalId], references: [id], onDelete: Restrict)
  area            Area            @relation(fields: [areaId], references: [id], onDelete: Restrict)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Restrict)
  assignedDoctor  DoctorProfile?  @relation(fields: [assignedDoctorId], references: [id], onDelete: SetNull)

  treatmentRecords TreatmentRecord[]
  prescriptions    Prescription[]
  billingRecords     BillingRecord[]

  @@index([status])
  @@index([customerId])
  @@index([assignedDoctorId, status])
  @@index([areaId, serviceCategoryId])
}

model TreatmentRecord {
  id              String                @id @default(cuid())
  serviceRequestId String
  doctorId        String
  animalId        String
  status          TreatmentRecordStatus @default(DRAFT)
  chiefComplaint  String?
  diagnosis       String?
  procedures      String?
  followUpNotes   String?
  recordedAt      DateTime              @default(now())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  animal         AnimalProfile  @relation(fields: [animalId], references: [id], onDelete: Restrict)

  @@index([serviceRequestId])
  @@index([doctorId])
}

model Prescription {
  id               String             @id @default(cuid())
  serviceRequestId String
  doctorId         String
  animalId         String
  status           PrescriptionStatus @default(ACTIVE)
  instructions     String?
  validUntil       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  animal         AnimalProfile  @relation(fields: [animalId], references: [id], onDelete: Restrict)

  @@index([serviceRequestId])
}

model BillingRecord {
  id               String             @id @default(cuid())
  serviceRequestId String
  doctorId         String
  customerId       String
  status           BillingRecordStatus @default(DRAFT)
  currency         String             @default("BDT")
  subtotal         Decimal            @db.Decimal(14, 2)
  tax              Decimal            @db.Decimal(14, 2)
  total            Decimal            @db.Decimal(14, 2)
  issuedAt         DateTime?
  paidAt           DateTime?
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  serviceRequest ServiceRequest  @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile   @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  customer       CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([doctorId])
  @@index([status])
}

model Notification {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  body         String
  readAt       DateTime?
  metadataJson Json?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
}
