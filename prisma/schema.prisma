// Prani Doctor — Prisma schema (MVP)
// https://pranidoctor.com/

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum UserRole {
  ADMIN
  CUSTOMER
  DOCTOR
  AI_TECHNICIAN
  SUPPORT
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  INVITED
  DELETED
}

enum ProviderStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
  OTHER
}

enum AnimalCategory {
  PET
  LIVESTOCK
  OTHER
}

enum AnimalType {
  CATTLE
  GOAT
  POULTRY
  DOG
  CAT
  OTHER
}

/// Reproductive status for applicable animals (e.g. livestock).
enum PregnancyStatus {
  UNKNOWN
  NOT_APPLICABLE
  NOT_PREGNANT
  PREGNANT
}

enum ServiceRequestType {
  DOCTOR_HOME_VISIT
  EMERGENCY_DOCTOR
  AI_SERVICE
  ONLINE_CONSULTATION_LATER
}

enum ServiceRequestStatus {
  PENDING
  ACCEPTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

enum TreatmentCaseStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum PrescriptionStatus {
  ACTIVE
  VOIDED
}

enum BillingStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOIDED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  CANCELLED
  /// MVP billing settlement (invoice-level); additive — gateway statuses above remain for PaymentRecord.
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  CARD
  BANK_TRANSFER
  OTHER
  /// MVP additions (Bangladesh mobile wallets / bank). Keep CARD/BANK_TRANSFER for legacy PaymentRecord rows.
  ROCKET
  BANK
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
  CLOSED
}

enum NotificationType {
  REQUEST_UPDATE
  PAYMENT
  CHAT
  SYSTEM
  MARKETING
  COMPLAINT
  REVIEW
}

/// Knowledge Hub / tutorial posts — editorial workflow (replaces legacy `ContentStatus` on `ContentPost`).
enum ContentApprovalStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

/// AI technician onboarding / marketplace lifecycle (distinct from legacy `ProviderStatus`).
enum AiTechnicianStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_CORRECTION
  APPROVED
  PUBLISHED
  REJECTED
  SUSPENDED
}

enum AiTechnicianDocumentType {
  NID_FRONT
  NID_BACK
  PROFILE_PHOTO
  /// Optional banner / background on technician profile card.
  COVER_IMAGE
  TRAINING_CERTIFICATE
  AI_CERTIFICATE
  COMPANY_ID
  EXPERIENCE_PROOF
  OTHER
}

enum AiTechnicianDocumentReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

/// Published technician service / gig row (distinct from `ServiceCategory` catalog).
enum AiTechnicianServiceStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  REJECTED
}

/// Farmer AI booking lifecycle (separate table from legacy `ServiceRequest`).
enum AiServiceRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  ON_THE_WAY
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Native AI module reviews (1:1 completed `AiServiceRequest`). Distinct from legacy `Review`.
enum AiTechnicianReviewVisibility {
  VISIBLE
  HIDDEN
}

enum AiTechnicianComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

/// Settlement for AI-specific request/record rows (distinct from invoice `PaymentStatus`).
enum AiPaymentStatus {
  UNPAID
  CASH_PAID
  MANUAL_PAID
  DUE
  REFUNDED
}

/// Mobile multipart upload `purpose` (universal upload pipeline; COMMAND 03).
enum MobileUploadPurpose {
  AI_TECHNICIAN_NID_FRONT
  AI_TECHNICIAN_NID_BACK
  AI_TECHNICIAN_PROFILE_PHOTO
  /// Technician profile banner / background (images only).
  AI_TECHNICIAN_COVER_IMAGE
  AI_TECHNICIAN_TRAINING_CERTIFICATE
  AI_TECHNICIAN_AI_CERTIFICATE
  AI_TECHNICIAN_OTHER
  /// Customer account — avatar shown in app (GET /api/mobile/uploads/[id] is public for this purpose).
  CUSTOMER_PROFILE_PHOTO
  /// Customer account — cover / background (GET … public for this purpose).
  CUSTOMER_COVER_IMAGE
}

enum UploadedFileStatus {
  ACTIVE
  DELETED
}

/// Administrative level for the unified `Area` tree (Bangladesh geography + optional service leaf).
enum AreaType {
  DIVISION
  DISTRICT
  UPAZILA
  UNION
  VILLAGE
  SERVICE_AREA
}

// --- Models ---

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  adminProfile         AdminProfile?
  doctorProfile        DoctorProfile?
  customerProfile      CustomerProfile?
  aiTechnicianProfile  AiTechnicianProfile?
  /// Admin users who last reviewed an AI technician profile (audit).
  aiTechnicianProfilesReviewed AiTechnicianProfile[] @relation("AiTechnicianProfileReviewedBy")
  customerAiServiceRequests    AiServiceRequest[]    @relation("AiServiceRequestCustomer")
  customerAiServiceRecords       AiServiceRecord[]    @relation("AiServiceRecordCustomer")
  aiTechnicianModuleReviewsWritten AiTechnicianReview[] @relation("AiTechnicianReviewAuthor")
  aiTechnicianModuleComplaintsFiled AiTechnicianComplaint[] @relation("AiTechnicianComplaintAuthor")
  notifications        Notification[]
  contentPostsAuthored ContentPost[]        @relation("ContentPostAuthor")
  complaintsAssigned   Complaint[]          @relation("ComplaintAssignee")
  uploadedFiles          UploadedFile[]

  @@index([role])
  @@index([status])
  @@index([role, status])
}

model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                        String         @id @default(cuid())
  userId                    String         @unique
  /// Display name shown to customers (identity email/phone stay on `User`).
  displayName               String?
  licenseNumber             String
  degree                    String?
  specialization            String?
  /// Years of professional experience (optional).
  experienceYears           Int?
  bio                       String?
  /// Placeholder or CDN URL for profile photo until uploads exist.
  profilePhotoUrl           String?
  visitFeeBdt               Decimal?       @db.Decimal(12, 2)
  acceptsEmergency          Boolean        @default(false)
  acceptsOnlineConsultation Boolean        @default(false)
  providerStatus            ProviderStatus @default(PENDING_VERIFICATION)
  verifiedAt                DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  user                           User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedRequests               ServiceRequest[]
  treatmentCases                 TreatmentCase[]
  prescriptions                  Prescription[]
  billingRecords                 BillingRecord[]
  doctorServiceAreas             DoctorServiceArea[]
  doctorProfileAreas             DoctorProfileArea[]
  doctorProfileServiceCategories DoctorProfileServiceCategory[]
  reviews                        Review[]
  complaints                     Complaint[]

  @@index([providerStatus])
}

model AiTechnicianProfile {
  id               String         @id @default(cuid())
  userId           String         @unique
  /// Display name shown to customers (identity email/phone stay on `User`).
  displayName      String?
  /// Optional public contact; canonical phone remains on `User.phone` when set.
  phone            String?
  /// Optional public contact; canonical email remains on `User.email`.
  email            String?
  nidNumber        String?
  dateOfBirth      DateTime?
  gender           Gender?
  presentAddress   String?        @db.Text
  district         String?
  upazila          String?
  unionOrArea      String?
  /// Optional FKs to normalized `District` / `Upazila` / `Union` (COMMAND 02). Legacy `district` / `upazila` / `unionOrArea` text retained.
  districtId       String?
  upazilaId        String?
  unionId          String?
  experienceYears  Int?
  trainingProvider String?
  certificateNumber String?
  certification    String?
  bio              String?
  /// Default fee for AI / technician field services (BDT).
  serviceFeeBdt    Decimal?       @db.Decimal(12, 2)
  /// Offers urgent / after-hours field AI support (dispatch rules live in product logic).
  acceptsEmergency Boolean        @default(false)
  /// Optional tags for MVP: e.g. livestock breeds, semen services (`{ "livestockFocus": ["cattle"], "semenServices": true }`).
  metadataJson     Json?
  /// Admin / onboarding lifecycle for technician module (see `AiTechnicianStatus`).
  status           AiTechnicianStatus @default(UNDER_REVIEW)
  providerStatus   ProviderStatus @default(PENDING_VERIFICATION)
  verifiedAt       DateTime?
  adminNote        String?        @db.Text
  correctionNote   String?        @db.Text
  reviewedById     String?
  reviewedAt       DateTime?
  publishedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user                                 User                                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy                           User?                                @relation("AiTechnicianProfileReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  bdDistrict                           District?                            @relation("AiTechnicianProfileDistrict", fields: [districtId], references: [id], onDelete: SetNull)
  bdUpazila                            Upazila?                             @relation("AiTechnicianProfileUpazila", fields: [upazilaId], references: [id], onDelete: SetNull)
  bdUnion                              Union?                               @relation("AiTechnicianProfileUnion", fields: [unionId], references: [id], onDelete: SetNull)
  assignedRequests                     ServiceRequest[]
  treatmentCases                       TreatmentCase[]
  prescriptions                        Prescription[]
  billingRecords                       BillingRecord[]
  aiTechnicianServiceAreas             AiTechnicianServiceArea[]
  aiTechnicianProfileAreas             AiTechnicianProfileArea[]
  aiTechnicianProfileServiceCategories AiTechnicianProfileServiceCategory[]
  divisionCoverageAreas                AiTechnicianDivisionServiceArea[]
  documents                            AiTechnicianDocument[]
  technicianServices                   AiTechnicianService[]
  aiServiceRequests                    AiServiceRequest[]                   @relation("AiServiceRequestTechnician")
  aiServiceRecords                     AiServiceRecord[]
  reviews                              Review[]
  complaints                           Complaint[]
  moduleReviews                        AiTechnicianReview[]                  @relation("AiTechnicianModuleReview")
  moduleComplaints                     AiTechnicianComplaint[]               @relation("AiTechnicianModuleComplaint")

  @@index([providerStatus])
  @@index([status])
  @@index([reviewedById])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
}

model CustomerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  locale      String?  @default("bn-BD")
  addressJson Json?
  /// HTTPS URL to display asset (same-origin `/api/mobile/uploads/:id` redirect or CDN).
  profilePhotoUrl String?
  coverPhotoUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  animals         AnimalProfile[]
  serviceRequests ServiceRequest[]
  billingRecords  BillingRecord[]
  reviews         Review[]
  complaints      Complaint[]
}

/// One active OTP challenge per normalized Bangladesh mobile (customer login).
model MobileOtpChallenge {
  id                  String    @id @default(cuid())
  normalizedPhone     String    @unique
  codeHash            String
  expiresAt           DateTime
  verifyAttempts      Int       @default(0)
  sendWindowStartedAt DateTime?
  sendsInWindow       Int       @default(0)
  /// Last time an OTP was successfully issued (for resend cooldown).
  lastOtpSentAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([expiresAt])
}

model Division {
  id         String   @id @default(cuid())
  /// Legacy display label (English-oriented seeds). Prefer `nameEn` / `nameBn` when set.
  name       String
  nameBn     String?
  nameEn     String?
  slug       String   @unique
  /// Not globally unique in legacy / merged seeds; match on slug + hierarchy when needed.
  code       String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  /// Centroid or verified point; null if unknown (never guessed).
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)
  /// Provenance, e.g. dataset id/version.
  source     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  districts District[]

  @@index([isActive])
  @@index([nameBn])
  @@index([nameEn])
  @@index([code])
}

model District {
  id         String   @id @default(cuid())
  divisionId String
  /// Legacy display label. Prefer `nameEn` / `nameBn` when set.
  name       String
  nameBn     String?
  nameEn     String?
  slug       String   @unique
  code       String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)
  source     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  division                        Division                         @relation(fields: [divisionId], references: [id], onDelete: Restrict)
  upazilas                        Upazila[]
  aiTechnicianProfilesAsDistrict  AiTechnicianProfile[]           @relation("AiTechnicianProfileDistrict")
  aiTechnicianDivisionAreasDistrict AiTechnicianDivisionServiceArea[] @relation("DivisionServiceAreaDistrict")

  @@index([divisionId])
  @@index([isActive])
  @@index([divisionId, code])
  @@index([divisionId, nameBn])
  @@index([divisionId, nameEn])
}

model Upazila {
  id         String   @id @default(cuid())
  districtId String
  name       String
  nameBn     String?
  nameEn     String?
  slug       String   @unique
  code       String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)
  source     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  district                         District                          @relation(fields: [districtId], references: [id], onDelete: Restrict)
  unions                           Union[]
  aiTechnicianProfilesAsUpazila    AiTechnicianProfile[]            @relation("AiTechnicianProfileUpazila")
  aiTechnicianDivisionAreasUpazila AiTechnicianDivisionServiceArea[] @relation("DivisionServiceAreaUpazila")

  @@index([districtId])
  @@index([isActive])
  @@index([districtId, code])
  @@index([districtId, nameBn])
  @@index([districtId, nameEn])
}

model Union {
  id         String   @id @default(cuid())
  upazilaId  String
  name       String
  nameBn     String?
  nameEn     String?
  slug       String   @unique
  code       String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)
  source     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  upazila                           Upazila                            @relation(fields: [upazilaId], references: [id], onDelete: Restrict)
  villages                          Village[]
  aiTechnicianProfilesAsUnion       AiTechnicianProfile[]             @relation("AiTechnicianProfileUnion")
  aiTechnicianDivisionAreasUnion     AiTechnicianDivisionServiceArea[]  @relation("DivisionServiceAreaUnion")

  @@index([upazilaId])
  @@index([isActive])
  @@index([upazilaId, code])
  @@index([upazilaId, nameBn])
  @@index([upazilaId, nameEn])
}

model Village {
  id         String   @id @default(cuid())
  unionId    String
  /// Legacy single label; prefer `nameBn` / `nameEn` when set.
  name       String
  nameBn     String?
  nameEn     String?
  slug       String   @unique
  code       String?
  isActive   Boolean  @default(true)
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)
  source     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  union                    Union                     @relation(fields: [unionId], references: [id], onDelete: Restrict)
  serviceRequests          ServiceRequest[]
  doctorServiceAreas       DoctorServiceArea[]
  aiTechnicianServiceAreas AiTechnicianServiceArea[]

  @@index([unionId])
  @@index([unionId, nameBn])
  @@index([unionId, nameEn])
  @@index([isActive])
}

/// Unified hierarchical area tree for Bangladesh geography (admin/API).
/// Coexists with normalized `Division`…`Village` tables; `ServiceRequest.areaId` remains optional during migration.
model Area {
  id           String   @id @default(cuid())
  name         String
  nameBn       String?
  slug         String   @unique
  code         String?
  type         AreaType @default(DIVISION)
  parentId     String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent                   Area?                     @relation("AreaHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children                 Area[]                    @relation("AreaHierarchy")
  serviceRequests          ServiceRequest[]
  doctorProfileAreas       DoctorProfileArea[]
  aiTechnicianProfileAreas AiTechnicianProfileArea[]

  @@index([parentId])
  @@index([type])
  @@index([isActive])
  @@index([parentId, type])
}

model DoctorServiceArea {
  id        String   @id @default(cuid())
  doctorId  String
  villageId String
  priority  Int?
  createdAt DateTime @default(now())

  doctor  DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  village Village       @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@unique([doctorId, villageId])
  @@index([villageId])
}

model AiTechnicianServiceArea {
  id             String   @id @default(cuid())
  aiTechnicianId String
  villageId      String
  priority       Int?
  createdAt      DateTime @default(now())

  aiTechnician AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  village      Village             @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@unique([aiTechnicianId, villageId])
  @@index([villageId])
}

model ServiceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serviceRequests                      ServiceRequest[]
  doctorProfileServiceCategories       DoctorProfileServiceCategory[]
  aiTechnicianProfileServiceCategories AiTechnicianProfileServiceCategory[]
}

/// Many-to-many: doctor coverage using the unified `Area` tree (admin geography).
model DoctorProfileArea {
  id        String   @id @default(cuid())
  doctorId  String
  areaId    String
  priority  Int?
  createdAt DateTime @default(now())

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  area   Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([doctorId, areaId])
  @@index([areaId])
}

/// Many-to-many: AI technician coverage using the unified `Area` tree (parallel to `DoctorProfileArea`).
model AiTechnicianProfileArea {
  id             String   @id @default(cuid())
  aiTechnicianId String
  areaId         String
  priority       Int?
  createdAt      DateTime @default(now())

  aiTechnician AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  area         Area                @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([aiTechnicianId, areaId])
  @@index([areaId])
}

/// Many-to-many: which service categories a doctor offers.
model DoctorProfileServiceCategory {
  id                String   @id @default(cuid())
  doctorId          String
  serviceCategoryId String
  createdAt         DateTime @default(now())

  doctor          DoctorProfile   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@unique([doctorId, serviceCategoryId])
  @@index([serviceCategoryId])
}

/// Many-to-many: which catalog services an AI technician provides (e.g. slug `ai-service`).
model AiTechnicianProfileServiceCategory {
  id                String   @id @default(cuid())
  aiTechnicianId    String
  serviceCategoryId String
  createdAt         DateTime @default(now())

  aiTechnician    AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  serviceCategory ServiceCategory     @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@unique([aiTechnicianId, serviceCategoryId])
  @@index([serviceCategoryId])
}

/// Declarative district-level service coverage (text labels or slugs).
/// Legacy village-level coverage remains on `AiTechnicianServiceArea`.
model AiTechnicianDivisionServiceArea {
  id             String   @id @default(cuid())
  aiTechnicianId String
  district       String
  upazila        String
  unionOrArea    String?
  /// Optional FKs to normalized geography; text columns above remain for search / legacy clients.
  districtId     String?
  upazilaId      String?
  unionId        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  aiTechnician AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  bdDistrict   District?          @relation("DivisionServiceAreaDistrict", fields: [districtId], references: [id], onDelete: SetNull)
  bdUpazila    Upazila?           @relation("DivisionServiceAreaUpazila", fields: [upazilaId], references: [id], onDelete: SetNull)
  bdUnion      Union?             @relation("DivisionServiceAreaUnion", fields: [unionId], references: [id], onDelete: SetNull)

  @@index([aiTechnicianId])
  @@index([district, upazila])
  @@index([districtId])
  @@index([upazilaId])
  @@index([unionId])
}

model AiTechnicianDocument {
  id               String                         @id @default(cuid())
  aiTechnicianId   String
  type             AiTechnicianDocumentType
  title            String
  /// Public or signed URL when objects are web-accessible.
  fileUrl          String?
  /// Opaque storage object key when using bucket-backed uploads.
  storageKey       String?
  mimeType         String?
  /// When set, file bytes and metadata live on `UploadedFile` (preferred path).
  uploadedFileId   String?                        @unique
  reviewStatus     AiTechnicianDocumentReviewStatus @default(PENDING_REVIEW)
  uploadedAt       DateTime                       @default(now())
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  aiTechnician AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  uploadedFile UploadedFile?       @relation(fields: [uploadedFileId], references: [id], onDelete: SetNull)

  @@index([aiTechnicianId])
  @@index([type])
}

/// Object storage metadata for universal mobile uploads (S3 / MinIO–compatible).
model UploadedFile {
  id            String               @id @default(cuid())
  ownerUserId   String
  bucket        String
  storageKey    String               @unique
  originalName  String
  mimeType      String
  sizeBytes     Int
  fileCategory  MobileUploadPurpose
  publicUrl     String?
  checksum      String?
  width         Int?
  height        Int?
  status        UploadedFileStatus   @default(ACTIVE)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  owner                 User                   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  aiTechnicianDocument AiTechnicianDocument?

  @@index([ownerUserId])
  @@index([status])
  @@index([fileCategory])
}

/// Technician-published service / gig (pricing + animal scope).
model AiTechnicianService {
  id                   String                  @id @default(cuid())
  aiTechnicianId       String
  title                String
  animalType           AnimalType
  breedOrSemenType     String?
  description          String?                 @db.Text
  basePrice            Decimal                 @db.Decimal(12, 2)
  visitFee             Decimal?                @db.Decimal(12, 2)
  emergencyFee         Decimal?                @db.Decimal(12, 2)
  repeatServicePolicy  String?                 @db.Text
  followUpIncluded     Boolean                 @default(false)
  status               AiTechnicianServiceStatus @default(DRAFT)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  aiTechnician AiTechnicianProfile @relation(fields: [aiTechnicianId], references: [id], onDelete: Cascade)
  aiServiceRequests AiServiceRequest[]

  @@index([aiTechnicianId])
  @@index([status])
  @@index([animalType])
}

/// Farmer-initiated AI service booking (module-native). Optional link to legacy `ServiceRequest` for integration.
model AiServiceRequest {
  id                   String                 @id @default(cuid())
  customerUserId       String
  technicianProfileId  String?
  serviceId            String?
  animalType           AnimalType
  breed                String?
  animalAge            String?
  lastHeatDate         DateTime?
  heatSymptoms         String?                @db.Text
  previousAiHistory    String?                @db.Text
  healthIssueNote      String?                @db.Text
  district             String
  upazila              String
  unionOrArea          String?
  addressDetail        String?                @db.Text
  preferredTime        String?
  isEmergency          Boolean                @default(false)
  /// Optional note when technician declines (native AI requests).
  declineReason        String?                @db.Text
  status               AiServiceRequestStatus @default(PENDING)
  estimatedFee         Decimal?               @db.Decimal(12, 2)
  finalFee             Decimal?               @db.Decimal(12, 2)
  paymentStatus        AiPaymentStatus        @default(UNPAID)
  linkedServiceRequestId String?            @unique
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  customer            User                  @relation("AiServiceRequestCustomer", fields: [customerUserId], references: [id], onDelete: Restrict)
  technicianProfile   AiTechnicianProfile?  @relation("AiServiceRequestTechnician", fields: [technicianProfileId], references: [id], onDelete: SetNull)
  service             AiTechnicianService?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  linkedServiceRequest ServiceRequest?      @relation(fields: [linkedServiceRequestId], references: [id], onDelete: SetNull)
  aiServiceRecord     AiServiceRecord?
  aiTechnicianReview  AiTechnicianReview?
  aiTechnicianComplaints AiTechnicianComplaint[]

  @@index([customerUserId])
  @@index([technicianProfileId])
  @@index([status])
  @@index([createdAt])
}

/// Structured outcome for a completed (or in-progress) AI visit.
model AiServiceRecord {
  id                   String          @id @default(cuid())
  aiServiceRequestId   String          @unique
  technicianProfileId  String
  customerUserId       String
  serviceDate          DateTime
  animalType           AnimalType
  breedOrSemenType     String?
  semenBatch           String?
  heatObservation      String?         @db.Text
  inseminationTime     DateTime?
  serviceNote          String?         @db.Text
  nextFollowUpDate     DateTime?
  pregnancyCheckDate   DateTime?
  totalFee             Decimal?        @db.Decimal(12, 2)
  paymentStatus        AiPaymentStatus @default(UNPAID)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  aiServiceRequest    AiServiceRequest    @relation(fields: [aiServiceRequestId], references: [id], onDelete: Cascade)
  technicianProfile   AiTechnicianProfile @relation(fields: [technicianProfileId], references: [id], onDelete: Restrict)
  customer            User                @relation("AiServiceRecordCustomer", fields: [customerUserId], references: [id], onDelete: Restrict)

  @@index([technicianProfileId])
  @@index([customerUserId])
  @@index([serviceDate])
}

/// Farmer rating after a completed native AI visit (one per `AiServiceRequest`).
model AiTechnicianReview {
  id                   String                     @id @default(cuid())
  aiServiceRequestId   String                     @unique
  technicianProfileId  String
  customerUserId       String
  rating               Int
  comment              String?                    @db.Text
  visibility           AiTechnicianReviewVisibility @default(VISIBLE)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  aiServiceRequest    AiServiceRequest    @relation(fields: [aiServiceRequestId], references: [id], onDelete: Cascade)
  technicianProfile   AiTechnicianProfile @relation("AiTechnicianModuleReview", fields: [technicianProfileId], references: [id], onDelete: Cascade)
  customer            User                @relation("AiTechnicianReviewAuthor", fields: [customerUserId], references: [id], onDelete: Restrict)

  @@index([technicianProfileId])
  @@index([customerUserId])
  @@index([visibility])
}

/// Farmer complaint for AI technician module (native requests).
model AiTechnicianComplaint {
  id                   String                     @id @default(cuid())
  aiServiceRequestId   String?
  technicianProfileId  String
  customerUserId       String
  category             String
  message              String                     @db.Text
  status               AiTechnicianComplaintStatus @default(OPEN)
  adminNote            String?                    @db.Text
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  aiServiceRequest    AiServiceRequest?   @relation(fields: [aiServiceRequestId], references: [id], onDelete: SetNull)
  technicianProfile   AiTechnicianProfile @relation("AiTechnicianModuleComplaint", fields: [technicianProfileId], references: [id], onDelete: Cascade)
  customer            User                @relation("AiTechnicianComplaintAuthor", fields: [customerUserId], references: [id], onDelete: Restrict)

  @@index([technicianProfileId])
  @@index([customerUserId])
  @@index([status])
  @@index([aiServiceRequestId])
}

model AnimalProfile {
  id              String           @id @default(cuid())
  customerId      String
  name            String
  species         String
  breed           String?
  category        AnimalCategory   @default(OTHER)
  animalType      AnimalType?
  weightKg        Decimal?         @db.Decimal(10, 3)
  dateOfBirth     DateTime?
  sex             String?
  gender          Gender?
  microchipOrTag  String?
  notes           String?
  photoUrl        String?
  pregnancyStatus PregnancyStatus?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  customer        CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceRequests ServiceRequest[]
  treatmentCases  TreatmentCase[]
  prescriptions   Prescription[]

  @@index([customerId])
}

model ServiceRequest {
  id                   String               @id @default(cuid())
  customerId           String
  animalId             String
  /// Legacy link — prefer `villageId` for new records.
  areaId               String?
  villageId            String?
  serviceCategoryId    String
  /// Stored as `requestType` in PostgreSQL (historic column name).
  serviceType          ServiceRequestType   @default(DOCTOR_HOME_VISIT) @map("requestType")
  assignedDoctorId     String?
  /// Stored as `assignedAiTechnicianId` in PostgreSQL (historic column name).
  assignedTechnicianId String?              @map("assignedAiTechnicianId")
  status               ServiceRequestStatus @default(PENDING)
  urgency              String?
  /// Stored as `symptoms` in PostgreSQL.
  problemOrSymptom     String?              @map("symptoms")
  description          String?
  /// Stored as `preferredWindow` in PostgreSQL.
  preferredTime        String?              @map("preferredWindow")
  /// Stored as `locationNotes` in PostgreSQL.
  locationText         String?              @map("locationNotes")
  scheduledStart       DateTime?
  scheduledEnd         DateTime?
  isEmergency          Boolean              @default(false)
  emergencyNotes       String?
  submittedAt          DateTime             @default(now())
  assignedAt           DateTime?
  startedAt            DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  completedAt          DateTime?

  customer           CustomerProfile      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  animal             AnimalProfile        @relation(fields: [animalId], references: [id], onDelete: Restrict)
  area               Area?                @relation(fields: [areaId], references: [id], onDelete: Restrict)
  village            Village?             @relation(fields: [villageId], references: [id], onDelete: Restrict)
  serviceCategory    ServiceCategory      @relation(fields: [serviceCategoryId], references: [id], onDelete: Restrict)
  assignedDoctor     DoctorProfile?       @relation(fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  assignedTechnician AiTechnicianProfile? @relation(fields: [assignedTechnicianId], references: [id], onDelete: SetNull)

  treatmentCases TreatmentCase[]
  prescriptions  Prescription[]
  billingRecords BillingRecord[]
  paymentRecords PaymentRecord[]
  reviews        Review[]
  complaints     Complaint[]
  linkedAiServiceRequest AiServiceRequest?

  @@index([status])
  @@index([customerId])
  @@index([animalId])
  @@index([assignedDoctorId, status])
  @@index([assignedTechnicianId, status])
  @@index([serviceType, status])
  @@index([areaId, serviceCategoryId])
  @@index([villageId])
}

/// Former `TreatmentRecord` table — mapped to preserve existing rows.
model TreatmentCase {
  id               String              @id @default(cuid())
  serviceRequestId String
  animalId         String
  doctorId         String?
  aiTechnicianId   String?
  status           TreatmentCaseStatus @default(DRAFT)
  chiefComplaint   String?
  symptoms         String?
  diagnosis        String?
  procedures       String?
  treatmentNotes   String?
  followUpNotes    String?
  followUpDate     DateTime?
  recordedAt       DateTime            @default(now())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  serviceRequest ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  animal         AnimalProfile        @relation(fields: [animalId], references: [id], onDelete: Restrict)
  doctor         DoctorProfile?       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  aiTechnician   AiTechnicianProfile? @relation(fields: [aiTechnicianId], references: [id], onDelete: Restrict)
  billingRecords BillingRecord[]

  @@index([serviceRequestId])
  @@index([doctorId])
  @@index([aiTechnicianId])
  @@index([status])
  @@map("TreatmentRecord")
}

model Prescription {
  id               String             @id @default(cuid())
  serviceRequestId String
  doctorId         String?
  aiTechnicianId   String?
  animalId         String
  status           PrescriptionStatus @default(ACTIVE)
  instructions     String?
  validUntil       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  serviceRequest ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile?       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  aiTechnician   AiTechnicianProfile? @relation(fields: [aiTechnicianId], references: [id], onDelete: Restrict)
  animal         AnimalProfile        @relation(fields: [animalId], references: [id], onDelete: Restrict)
  items          PrescriptionItem[]

  @@index([serviceRequestId])
  @@index([doctorId])
  @@index([aiTechnicianId])
}

model PrescriptionItem {
  id             String   @id @default(cuid())
  prescriptionId String
  medicineName   String
  dosage         String?
  duration       String?
  instruction    String?
  quantity       Decimal? @db.Decimal(12, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

model BillingRecord {
  id                 String         @id @default(cuid())
  serviceRequestId   String
  treatmentCaseId    String?
  doctorId           String?
  aiTechnicianId     String?
  customerId         String
  status             BillingStatus  @default(DRAFT)
  currency           String         @default("BDT")
  /// Legacy aggregates — nullable while migrating to fee breakdown fields.
  subtotal           Decimal?       @db.Decimal(14, 2)
  tax                Decimal?       @db.Decimal(14, 2)
  total              Decimal?       @db.Decimal(14, 2)
  serviceFee         Decimal?       @db.Decimal(14, 2)
  travelCost         Decimal?       @db.Decimal(14, 2)
  medicineCost       Decimal?       @db.Decimal(14, 2)
  discountAmount     Decimal?       @db.Decimal(14, 2)
  totalCollected     Decimal?       @db.Decimal(14, 2)
  platformCommission Decimal?       @db.Decimal(14, 2)
  providerPayout     Decimal?       @db.Decimal(14, 2)
  /// Primary/settlement method for this invoice (optional if only PaymentRecord lines are used).
  paymentMethod      PaymentMethod?
  /// MVP payment settlement status at invoice level (distinct from BillingStatus lifecycle).
  paymentStatus      PaymentStatus  @default(UNPAID)
  issuedAt           DateTime?
  paidAt             DateTime?
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  serviceRequest ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  treatmentCase  TreatmentCase?       @relation(fields: [treatmentCaseId], references: [id], onDelete: SetNull)
  doctor         DoctorProfile?       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  aiTechnician   AiTechnicianProfile? @relation(fields: [aiTechnicianId], references: [id], onDelete: Restrict)
  customer       CustomerProfile      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentRecords PaymentRecord[]
  complaints     Complaint[]

  @@index([customerId])
  @@index([doctorId])
  @@index([aiTechnicianId])
  @@index([status])
}

model PaymentRecord {
  id               String        @id @default(cuid())
  billingRecordId  String?
  serviceRequestId String?
  status           PaymentStatus @default(PENDING)
  method           PaymentMethod
  amount           Decimal       @db.Decimal(14, 2)
  currency         String        @default("BDT")
  externalId       String?
  paidAt           DateTime?
  metadataJson     Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  billingRecord  BillingRecord?  @relation(fields: [billingRecordId], references: [id], onDelete: SetNull)
  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)

  @@index([billingRecordId])
  @@index([serviceRequestId])
  @@index([status])
  @@index([externalId])
}

model Review {
  id               String       @id @default(cuid())
  customerId       String
  doctorId         String?
  aiTechnicianId   String?
  serviceRequestId String?
  rating           Int
  comment          String?
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  customer       CustomerProfile      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile?       @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  aiTechnician   AiTechnicianProfile? @relation(fields: [aiTechnicianId], references: [id], onDelete: SetNull)
  serviceRequest ServiceRequest?      @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)

  @@index([customerId, serviceRequestId])
  @@index([doctorId])
  @@index([aiTechnicianId])
  @@index([status])
}

/// Tutorial / Knowledge Hub article (author = `User`: doctor or admin).
model ContentCategory {
  id          String   @id @default(cuid())
  nameBn      String
  nameEn      String?
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts ContentPost[]

  @@index([isActive, sortOrder])
}

model ContentPost {
  id              String                @id @default(cuid())
  title           String
  slug            String                @unique
  summary         String?
  body            String                @db.Text
  coverImageUrl   String?
  categoryId      String
  category        ContentCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  authorId        String
  author          User                  @relation("ContentPostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  approvalStatus  ContentApprovalStatus @default(DRAFT)
  rejectionReason String?
  publishedAt     DateTime?
  isPublished     Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([approvalStatus])
  @@index([authorId])
  @@index([categoryId])
  @@index([isPublished, publishedAt])
}

model Complaint {
  id               String          @id @default(cuid())
  customerId       String
  doctorId         String?
  aiTechnicianId   String?
  adminAssigneeId  String?
  serviceRequestId String?
  billingRecordId  String?
  status           ComplaintStatus @default(OPEN)
  resolutionNotes  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  customer       CustomerProfile      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile?       @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  aiTechnician   AiTechnicianProfile? @relation(fields: [aiTechnicianId], references: [id], onDelete: SetNull)
  adminAssignee  User?                @relation("ComplaintAssignee", fields: [adminAssigneeId], references: [id], onDelete: SetNull)
  serviceRequest ServiceRequest?      @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  billingRecord  BillingRecord?       @relation(fields: [billingRecordId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerId])
  @@index([adminAssigneeId])
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  type         NotificationType @default(SYSTEM)
  title        String
  body         String
  readAt       DateTime?
  metadataJson Json?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
}
