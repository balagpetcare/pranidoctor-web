# Prani Doctor — local environment (copy to `.env` in this folder and adjust)

# PostgreSQL (local Docker — see docker-compose.yml and docs/LOCAL_DATABASE_SETUP.md)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pranidoctor_db?schema=public"

# HS256 secret for admin JWT cookie (min 32 characters). Generate e.g. openssl rand -base64 48
ADMIN_JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
