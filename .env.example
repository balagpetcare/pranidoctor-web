# =============================================================================
# Prani Doctor — example environment (safe placeholders only)
# Copy to `.env`, fill real values, and never commit `.env`.
# See docs/ENV_SETUP.md for what the running app reads today vs future keys.
# =============================================================================

# --- App ---
NODE_ENV=development
APP_NAME="Prani Doctor"
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# --- Database (required) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pranidoctor?schema=public"

# --- Admin seed (`npm run seed:admin` / full `npm run db:seed`) ---
ADMIN_SEED_EMAIL=admin@pranidoctor.com
ADMIN_SEED_PASSWORD=change-this-strong-password
ADMIN_SEED_NAME="Prani Doctor Admin"
ADMIN_SEED_PHONE=01700000000

# Legacy panel admin names (optional; lower precedence than ADMIN_SEED_* in prisma/seed.ts)
# DEFAULT_ADMIN_EMAIL=
# DEFAULT_ADMIN_PASSWORD=
# PRANI_SEED_ADMIN_EMAIL=
# PRANI_SEED_ADMIN_PASSWORD=

# --- Auth / JWT (signing secrets must be ≥32 characters after trim) ---
# Admin cookie JWT: prefers ADMIN_JWT_SECRET, then AUTH_SECRET, then JWT_SECRET.

JWT_SECRET=31760c54678415a58f1da8d48db7798be3310326a8e110c0e00f753bd6ffe3f3829bb96f7b8b6fe381d52f6b4713f6cc
ADMIN_JWT_SECRET=7b074a45116c45828105ab0df3d3ae7f06a448e8930aa47cdbab62f3a86298d534fd1e7a84736d6b0d7a74ad1697e2b9
AUTH_SECRET=9758d3000cbeaddac35246669fa5968f97c2b937fac7a16465d7c468a4b82077f4df9694a26c376808334694e9712584        
DOCTOR_JWT_SECRET=2129fafec8b52dfd144790b069bf9da9f83f28e030119b91223c6bb2fcd759a30d946c2ddcb5a4e64043258e3e1cd0ff  
TECHNICIAN_JWT_SECRET=0999d95b4f362b7aa73651ad984f4c43fab00007d11f34fa208874a56c7aca0e89ad257f0bd8a92884ec0b6c0167bb86
MOBILE_JWT_SECRET=ead90f9ae1f0a30d1331d961a37bc54321c88b2ec7b88533e797875f91d2455f4a1b3f4bf0511a65f26321281aac1149  



# NextAuth placeholders (not used by current custom JWT auth unless you add NextAuth)
NEXTAUTH_SECRET=replace-with-at-least-32-characters-secret
NEXTAUTH_URL=http://localhost:3000

# Reserved for future wiring — live admin cookie name is still `prani_admin_session` in code.
SESSION_COOKIE_NAME=prani_admin_session

# Reserved / future — admin session length is fixed in code (7 days) unless you wire this.
TOKEN_EXPIRES_IN=7d

# --- OTP (mobile customer flow uses hardcoded TTL/rate limits in otp-constants.ts; these are future-friendly) ---
OTP_EXPIRES_MINUTES=5
OTP_LENGTH=6
OTP_RATE_LIMIT_PER_PHONE=5
ENABLE_DEV_OTP=true
OTP_DEV_CODE=123456

# --- SMS (implemented: SMS_PROVIDER + optional SMS_HTTP_* for http provider) ---
SMS_ENABLED=false
SMS_PROVIDER=local
SMS_HTTP_URL=
SMS_HTTP_API_KEY=
SMS_API_KEY=paste-your-sms-api-key-here
SMS_SENDER_ID=paste-your-approved-sender-id-here
SMS_BASE_URL=paste-your-sms-api-url-here
SMS_OTP_TEMPLATE="Your Prani Doctor OTP is {{code}}"

# --- Notifications / feature toggles (FEATURE_* are placeholders unless read by your branch) ---
FEATURE_NOTIFICATIONS=true
FEATURE_SMS=false
FEATURE_ADMIN_PANEL=true
FEATURE_CUSTOMER_APP=true
FEATURE_DOCTOR_PANEL=true
FEATURE_AI_TECHNICIAN=true
FEATURE_PAYMENT=false
FEATURE_KNOWLEDGE_HUB=true

# --- Payment placeholders ---
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=manual
BKASH_APP_KEY=paste-your-bkash-app-key-here
BKASH_APP_SECRET=paste-your-bkash-app-secret-here
BKASH_USERNAME=paste-your-bkash-username-here
BKASH_PASSWORD=paste-your-bkash-password-here
BKASH_BASE_URL=paste-your-bkash-base-url-here

# --- Storage placeholders ---
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
S3_ENDPOINT=paste-your-s3-endpoint-here
S3_ACCESS_KEY=paste-your-s3-access-key-here
S3_SECRET_KEY=paste-your-s3-secret-key-here
S3_BUCKET=prani-doctor
S3_REGION=ap-south-1

# --- Email / support ---
SUPPORT_EMAIL=support@pranidoctor.com
SUPPORT_PHONE=01700000000
MAIL_ENABLED=false
MAIL_HOST=paste-your-mail-host-here
MAIL_PORT=587
MAIL_USER=paste-your-mail-user-here
MAIL_PASSWORD=paste-your-mail-password-here
MAIL_FROM="Prani Doctor <support@pranidoctor.com>"

# --- Optional: demo seed users (non-production only; see prisma/seed.ts) ---
# PRANI_SEED_DEMO=true

# =============================================================================
# Optional / extended (may exist in local `.env`; not all are read by the app)
# =============================================================================
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_NAME="Prani Doctor"
# BCRYPT_SALT_ROUNDS=12
# OTP_RESEND_SECONDS=60
# OTP_MAX_ATTEMPTS=5
# EMAIL_PROVIDER=local
# SMTP_HOST=paste-your-smtp-host-here
# SMTP_PORT=587
# SMTP_USER=paste-your-smtp-user-here
# SMTP_PASSWORD=paste-your-smtp-password-here
# EMAIL_FROM="Prani Doctor <no-reply@pranidoctor.com>"
# NEXT_PUBLIC_UPLOAD_BASE_URL=http://localhost:3000/uploads
# S3_ACCESS_KEY_ID=paste-your-access-key-id-here
# S3_SECRET_ACCESS_KEY=paste-your-secret-access-key-here
# S3_FORCE_PATH_STYLE=true
# NAGAD_BASE_URL=
# SSLCOMMERZ_STORE_ID=
# CORS_ORIGIN=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# LOG_LEVEL=debug
# PRISMA_LOG_LEVEL=warn
